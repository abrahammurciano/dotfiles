#!/usr/bin/env bash

set -euo pipefail

# Default configuration
SOURCE="${DOT_SOURCE:-$HOME/.dotfiles}"
TARGET="${DOT_TARGET:-$HOME}"

# Make a path relative to the target directory
# Args: file_path - path to file, must be within TARGET
# Returns: the path relative to TARGET
relative_path() {
    local file="$1"
    if [[ "$file" != /* ]]; then
		file="$(pwd)/$file"
    fi
	if [[ "$file" != "$TARGET"* ]]; then
		echo "Error: Path $file must be within $TARGET" >&2
		return 1
	fi
	echo "${file#$TARGET/}"
}

usage() {
    echo "Usage: $0 <command> [args...]"
    echo ""
    echo "Commands:"
    echo "  adopt PACKAGE FILE...   Adopt files into the dotfiles repository"
    echo "  save [MESSAGE]          Save changes (git add, commit, push)"
    echo ""
    echo "Environment:"
    echo "  DOT_SOURCE              Dotfiles source (default: ~/.dotfiles)"
    echo "  DOT_TARGET              Target directory (default: ~)"
}

adopt_file() {
	local package="$1"
	local file="$2"
	local relative_file=$(relative_path "$file")
	local source_file="$SOURCE/$package/$relative_file"

	mkdir -p "$(dirname "$file")" "$(dirname "$source_file")"
	touch "$file" "$source_file"
	(cd "$SOURCE" && stow --adopt "$package")
}

adopt() {
    local package="$1"
    shift

	if [[ -z "$package" || $# -eq 0 ]]; then
		echo "Error: PACKAGE and at least one FILE argument are required"
		echo "Usage: $0 adopt PACKAGE FILE [FILE2 FILE3...]"
		return 1
	fi

    for file in "$@"; do
        adopt_file "$package" "$file"
    done
}

save() {
    local commit_msg="${1:-"Update dotfiles $(date +%Y-%m-%d)"}"
    cd "$SOURCE"
    if git status --porcelain | grep -q '^'; then
        git add .
        git commit -m "$commit_msg"
        git push
    else
        echo "No changes to save"
    fi
}

case "$1" in
    adopt)
        shift
        adopt "$@"
        ;;
    save)
        shift
        save "$@"
        ;;
    -h|--help|help)
        usage
        ;;
    "")
        usage
        ;;
    *)
        echo "Error: Unknown command '$1'"
        usage
        exit 1
        ;;
esac